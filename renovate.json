{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitTypeAll(chore)"
  ],
  "addLabels": [
    "dependencies"
  ],
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "groupName": "geotools",
      "matchDepNames": [
        "org.geotools"
      ],
      "matchPackagePrefixes": [
        "org.geotools:"
      ]
    },
    {
      "groupName": "mapstruct",
      "matchDepNames": [
        "org.mapstruct"
      ],
      "matchPackagePrefixes": [
        "org.mapstruct:"
      ]
    },
    {
      "groupName": "githubActions",
      "matchDepTypes": [
        "action"
      ],
      "automerge": true
    }
  ]
}
