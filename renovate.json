{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitTypeAll(chore)"
  ],
  "addLabels": [
    "dependencies"
  ],
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "groupName": "geotools",
      "matchDepNames": [
        "org.geotools"
      ],
      "matchPackagePrefixes": [
        "org.geotools:"
      ]
    },
    {
      "groupName": "mapstruct",
      "matchDepNames": [
        "org.mapstruct"
      ],
      "matchPackagePrefixes": [
        "org.mapstruct:"
      ]
    },
    {
      "groupName": "LocalDockerComposeFiles",
      "description": "Docker-compose files only used for local testing to be auto merged",
      "matchFileNames": [
        "**/docker-compose.yaml",
        "**/docker-compose-extended.yaml"
      ],
      "automerge": true,
      "autoApprove": true
    },
    {
      "groupName": "GithubActions",
      "matchDepTypes": [
        "action"
      ]
    },
    {
      "groupName": "GithubActions non major",
      "description": "Github actions that are non major to be auto merged",
      "matchDepTypes": [
        "action"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "autoApprove": true
    }
  ]
}
